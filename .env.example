# Copiez ce fichier en `.env` et renseignez vos valeurs.
# `.env` est gitignoré : n'y mettez jamais de secret dans le dépôt.
# Chargé/validé via pydantic-settings (SecuritySettings, préfixe BAOBAB_SECURITY_).

# Émetteur et audience des tokens (optionnels)
BAOBAB_SECURITY_ISSUER=baobab-auth
BAOBAB_SECURITY_AUDIENCE=api

# Signature
BAOBAB_SECURITY_ALGORITHM=RS256
BAOBAB_SECURITY_KEY_SIZE=2048

# Durées de vie (secondes)
BAOBAB_SECURITY_ACCESS_TTL_SECONDS=900
BAOBAB_SECURITY_REFRESH_TTL_SECONDS=1209600

# Paramètres Argon2id
BAOBAB_SECURITY_ARGON2_TIME_COST=3
BAOBAB_SECURITY_ARGON2_MEMORY_COST=65536
BAOBAB_SECURITY_ARGON2_PARALLELISM=4
